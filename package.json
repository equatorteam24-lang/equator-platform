{
  "name": "equator-platform",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "dev:super-admin": "turbo run dev --filter=@equator/super-admin",
    "dev:site-template": "turbo run dev --filter=@equator/site-template"
  },
  "devDependencies": {
    "turbo": "^2.3.4"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
